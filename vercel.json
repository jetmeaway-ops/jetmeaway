{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/flights/deals?refresh=1",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/deal-alerts/send",
      "schedule": "0 10 * * 3"
    },
    {
      "path": "/api/cron/check-saved-searches",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/scout/reminders",
      "schedule": "0 9 * * *"
    }
  ]
}
