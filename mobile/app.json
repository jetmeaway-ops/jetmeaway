{
  "expo": {
    "name": "JetMeAway",
    "slug": "jetmeaway",
    "version": "1.0.6",
    "scheme": "jetmeaway",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A1230"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uk.co.jetmeaway.app",
      "buildNumber": "10",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:jetmeaway.co.uk",
        "applinks:www.jetmeaway.co.uk",
        "webcredentials:jetmeaway.co.uk"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "JetMeAway uses your location to suggest the nearest airport and map the neighbourhood around your hotel. Location is never shared or sold.",
        "NSUserNotificationsUsageDescription": "JetMeAway sends deal alerts when hotel and flight prices drop on routes you've shown interest in. You can turn this off any time in Settings.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1458B5"
      },
      "package": "uk.co.jetmeaway.app",
      "versionCode": 20,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "jetmeaway.co.uk" },
            { "scheme": "https", "host": "www.jetmeaway.co.uk" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {},
    "primaryColor": "#0066FF",
    "plugins": [
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "JetMeAway uses your location to suggest the nearest airport and map the neighbourhood around your hotel. Location is never shared or sold."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0066FF",
          "defaultChannel": "default"
        }
      ],
      "expo-apple-authentication",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "faf61588-3700-4917-acbe-bc9a3569fc33"
      },
      "googleAuth": {
        "iosClientId": "24845514965-u0lsphq80d7p92ba7mui30kp3cgm7cr6.apps.googleusercontent.com",
        "androidClientId": "24845514965-ie41mnpu907ne6aktgrvr4e9d18cdpuh.apps.googleusercontent.com",
        "webClientId": "24845514965-58go8v35r6nf47c75fu79rsd0b4j6g0g.apps.googleusercontent.com"
      }
    },
    "owner": "jetmeaway"
  }
}
