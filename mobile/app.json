{
  "expo": {
    "name": "JetMeAway",
    "slug": "jetmeaway",
    "version": "1.0.5",
    "scheme": "jetmeaway",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A1230"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uk.co.jetmeaway.app",
      "buildNumber": "5",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "JetMeAway uses your location to suggest the nearest airport and map the neighbourhood around your hotel. Location is never shared or sold.",
        "NSUserNotificationsUsageDescription": "JetMeAway sends deal alerts when hotel and flight prices drop on routes you've shown interest in. You can turn this off any time in Settings.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1458B5"
      },
      "package": "uk.co.jetmeaway.app",
      "versionCode": 15,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {},
    "primaryColor": "#0066FF",
    "plugins": [
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "JetMeAway uses your location to suggest the nearest airport and map the neighbourhood around your hotel. Location is never shared or sold."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0066FF",
          "defaultChannel": "default"
        }
      ],
      "expo-apple-authentication",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "faf61588-3700-4917-acbe-bc9a3569fc33"
      },
      "googleAuth": {
        "iosClientId": "REPLACE_WITH_GOOGLE_OAUTH_IOS_CLIENT_ID",
        "androidClientId": "REPLACE_WITH_GOOGLE_OAUTH_ANDROID_CLIENT_ID",
        "webClientId": "REPLACE_WITH_GOOGLE_OAUTH_WEB_CLIENT_ID"
      }
    },
    "owner": "jetmeaway"
  }
}
