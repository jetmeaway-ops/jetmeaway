# EAS Build only needs files inside mobile/.
# Running `eas build` from this directory, EAS still uses the git root
# for context, which pulls in the Next.js web app at ../src. The Linux
# build server's tar fails extracting folder names with square brackets
# like src/app/api/hotels/pending/[ref]/, which tanks the build.
# This .easignore (relative to the repo git root) excludes the web app
# so only the Expo project is uploaded.

# Next.js web app and related
/src/
/public/
/docs/
/scripts/
/.next/
/out/
/coverage/
/build/

# Root-level web app config
/package.json
/package-lock.json
/next.config.*
/next-env.d.ts
/tsconfig.json
/tailwind.config.*
/postcss.config.*
/vercel.json
/README.md
/AGENTS.md
/CLAUDE.md
/middleware.ts
/middleware.js

# Node modules (always)
node_modules/

# Vercel / environment / local state
.vercel/
.env*
.claude/
.git/
.expo/

# Misc web-only data files
flights.json
offer.json
*.tsbuildinfo
