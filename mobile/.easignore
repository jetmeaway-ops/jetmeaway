# EAS Build archives from the git root. When .easignore is present it
# REPLACES .gitignore for the archive. Patterns follow gitignore syntax
# and match anywhere in the tree (so `src/` excludes any directory named
# src at any depth — including the Next.js web app at the repo root).
#
# Previous Android build failed in PREPARE_PROJECT because tar on the
# Linux build server choked extracting Next.js App Router dynamic-route
# folders (src/app/api/hotels/pending/[ref]/ etc). The web app isn't
# needed for the Expo mobile build, so we exclude it entirely.

# --- Next.js web app (lives at ../ relative to this file) ---
src/
public/
docs/
scripts/
.next/
out/
coverage/
build/

# --- Root-level web app config (only exists at repo root, not in mobile/) ---
# Match by name; won't clash with mobile/package.json since that's what EAS needs.
/package.json
/package-lock.json
/next.config.js
/next.config.ts
/next.config.mjs
/next-env.d.ts
/tsconfig.json
/tailwind.config.js
/tailwind.config.ts
/postcss.config.js
/postcss.config.mjs
/vercel.json
/README.md
/AGENTS.md
/CLAUDE.md
/middleware.ts
/middleware.js
/flights.json
/offer.json

# --- Always-excluded ---
node_modules/
.vercel/
.env
.env.*
.claude/
.expo/
*.tsbuildinfo
*.log
