# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# Expo / React Native
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/android/
mobile/ios/

# Claude Code local session state
.claude/

.env*.local
flights.json
offer.json

# Broadcast scripts — customer PII must never be committed
scripts/*.local.json
scripts/broadcast-contacts*.json
!scripts/broadcast-contacts.example.json

# Claude Code memory snapshot — human-readable mirror of ~/.claude/projects/...
# Contains private notes, customer phone numbers, partner deal terms.
# NEVER commit. Live source of truth lives in ~/.claude/ (also gitignored above).
jetmeaway-memory/
