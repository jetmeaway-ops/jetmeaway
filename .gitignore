# Broadcast scripts — customer PII must never be committed
scripts/*.local.json
scripts/broadcast-contacts*.json
!scripts/broadcast-contacts.example.json

# Claude Code memory snapshot — human-readable mirror of ~/.claude/projects/...
# Contains private notes, customer phone numbers, partner deal terms.
# NEVER commit. Live source of truth lives in ~/.claude/ (also gitignored above).
jetmeaway-memory/
.playwright-mcp/

# App Store Connect screenshot upload tooling — one-off generated artifacts
# (base64 image blobs, chunked injection scripts, local screenshot server)
scripts/asc-inject.js
scripts/asc-chunks/
scripts/asc-mini/
scripts/build-asc-injection.mjs
scripts/build-asc-injection-chunked.mjs
scripts/build-asc-injection-mini.mjs
scripts/fix-alpha-asc-screenshots.mjs
scripts/serve-screenshots.mjs

# Apple Brand Profile cover photo — generated artifact, reproducible from
# scripts/build-apple-cover.mjs. Lives uploaded on Apple Business Manager,
# no need to ship the PNG bytes through git.
/public/apple-brand-cover-1600x1040.png
